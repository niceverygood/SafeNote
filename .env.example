# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API (해석·초안·문장화 전용 — 규정 매핑/위험도 산정 금지)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Voyage AI (RAG 임베딩)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# 스티비(stibee) 이메일 너처링 — 리드/구독 자동 등록 (선택, 없으면 스킵)
STIBEE_API_KEY=
STIBEE_LIST_ID=

# Solapi SMS — 위험 신고(높음) 시 관리자 실시간 알림 (선택, 없으면 스킵)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=

# 사이트 URL (QR 등 절대경로 생성용 — 미설정 시 운영 도메인 폴백)
NEXT_PUBLIC_SITE_URL=

# 테스트 로그인 (운영 전환 시 false)
NEXT_PUBLIC_ENABLE_TEST_LOGIN=true

# 테스트 로그인 데모 계정 (NEXT_PUBLIC_ENABLE_TEST_LOGIN=true 일 때 사용)
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=
DEMO_WORKER_USERNAME=
